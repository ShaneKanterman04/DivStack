    "react-dom": "19.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.18.6",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "autoprefixer": "10.4.21",
    "eslint": "9.35.0",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "16.4.0",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "prisma": "6.15.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.20.5",
